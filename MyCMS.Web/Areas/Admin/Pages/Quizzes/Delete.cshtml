@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Quizzes.DeleteModel
@{
    ViewData["Title"] = "Delete Quiz";
    Layout = "_AdminLayout";
}

<h1>Delete Quiz</h1>

<h3>Are you sure you want to delete this quiz?</h3>

<div>
    <h4>Quiz</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Quiz?.Title</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Quiz?.Description</dd>

        <dt class="col-sm-2">Time Limit</dt>
        <dd class="col-sm-10">@Model.Quiz?.TimeLimitMinutes minutes</dd>

        <dt class="col-sm-2">Passing Score</dt>
        <dd class="col-sm-10">@Model.Quiz?.PassingScore%</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Quiz.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
