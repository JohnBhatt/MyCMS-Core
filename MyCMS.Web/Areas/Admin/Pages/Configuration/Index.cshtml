@page
@model MyCMS.Web.Areas.Admin.Pages.Configuration.IndexModel
@{
    ViewData["Title"] = "Configuration";
    Layout = "_AdminLayout";
}

<h1>Site Configuration</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h4>General Settings</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="Config.SiteName" class="control-label"></label>
                <input asp-for="Config.SiteName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.Slogan" class="control-label"></label>
                <input asp-for="Config.Slogan" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.BaseURL" class="control-label">Base URL</label>
                <input asp-for="Config.BaseURL" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.FooterText" class="control-label">Footer Text</label>
                <textarea asp-for="Config.FooterText" class="form-control" rows="2"></textarea>
            </div>

            <h4>Social Media</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="Config.FacebookLink" class="control-label">Facebook</label>
                <input asp-for="Config.FacebookLink" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.LinkedInLink" class="control-label">LinkedIn</label>
                <input asp-for="Config.LinkedInLink" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.TwitterLink" class="control-label">Twitter</label>
                <input asp-for="Config.TwitterLink" class="form-control" />
            </div>

            <h4>SEO</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="Config.Keywords" class="control-label">Meta Keywords</label>
                <input asp-for="Config.Keywords" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.MetaDesc" class="control-label">Meta Description</label>
                <textarea asp-for="Config.MetaDesc" class="form-control" rows="2"></textarea>
            </div>

            <h4>Sitemap</h4>
            <hr />
            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Config.SitemapEnabled" />
                <label class="form-check-label" asp-for="Config.SitemapEnabled">Enable Sitemap</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.SitemapPriority" class="control-label">Default Priority</label>
                <input asp-for="Config.SitemapPriority" type="number" step="0.1" min="0" max="1" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.SitemapChangeFrequency" class="control-label">Change Frequency</label>
                <select asp-for="Config.SitemapChangeFrequency" class="form-control">
                    <option value="always">Always</option>
                    <option value="hourly">Hourly</option>
                    <option value="daily">Daily</option>
                    <option value="weekly">Weekly</option>
                    <option value="monthly">Monthly</option>
                    <option value="yearly">Yearly</option>
                    <option value="never">Never</option>
                </select>
            </div>

            <h4>RSS Feed</h4>
            <hr />
            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Config.RSSFeedEnabled" />
                <label class="form-check-label" asp-for="Config.RSSFeedEnabled">Enable RSS Feed</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.RSSFeedTitle" class="control-label">Feed Title</label>
                <input asp-for="Config.RSSFeedTitle" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.RSSFeedItemCount" class="control-label">Item Count</label>
                <input asp-for="Config.RSSFeedItemCount" type="number" class="form-control" />
            </div>

            <h4>Custom Scripts</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="Config.HeadScript" class="control-label">Head Script (Google Analytics, Adsense, etc.)</label>
                <textarea asp-for="Config.HeadScript" class="form-control" rows="5"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.BodyScript" class="control-label">Body Script</label>
                <textarea asp-for="Config.BodyScript" class="form-control" rows="5"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.GoogleAnalyticsId" class="control-label">Google Analytics ID</label>
                <input asp-for="Config.GoogleAnalyticsId" class="form-control" placeholder="UA-XXXXX-X" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.GoogleAdsenseId" class="control-label">Google Adsense ID</label>
                <input asp-for="Config.GoogleAdsenseId" class="form-control" placeholder="ca-pub-XXXXXXXXXXXXXXXX" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.FacebookPixelId" class="control-label">Facebook Pixel ID</label>
                <input asp-for="Config.FacebookPixelId" class="form-control" placeholder="XXXXXXXXXXXXXXXX" />
            </div>

            <h4>AMP</h4>
            <hr />
            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Config.AMPEnabled" />
                <label class="form-check-label" asp-for="Config.AMPEnabled">Enable AMP</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.AMPAnalyticsId" class="control-label">AMP Analytics ID</label>
                <input asp-for="Config.AMPAnalyticsId" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.AMPLogoUrl" class="control-label">AMP Logo URL</label>
                <input asp-for="Config.AMPLogoUrl" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Config.AMPublisherName" class="control-label">Publisher Name</label>
                <input asp-for="Config.AMPublisherName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save Configuration" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
