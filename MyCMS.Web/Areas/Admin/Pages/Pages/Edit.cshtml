@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Pages.EditModel
@{
    ViewData["Title"] = "Edit Page";
    Layout = "_AdminLayout";
}

<h1>Edit Page</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Page.Id" />

            <div class="form-group mb-3">
                <label asp-for="Page.PageTitle" class="control-label"></label>
                <input asp-for="Page.PageTitle" class="form-control" required />
                <span asp-validation-for="Page.PageTitle" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Page.PageURL" class="control-label"></label>
                <input asp-for="Page.PageURL" class="form-control" required />
                <span asp-validation-for="Page.PageURL" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Page.ParentPage" class="control-label">Parent Page</label>
                <select asp-for="Page.ParentPage" class="form-control" asp-items="Model.ParentPages">
                    <option value="">-- None --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Page.PageSummary" class="control-label"></label>
                <textarea asp-for="Page.PageSummary" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Page.PageBody" class="control-label">Content</label>
                <div id="editor-container" style="height: 300px;"></div>
                <input type="hidden" asp-for="Page.PageBody" id="pageBody" />
            </div>

            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Page.IsHomePage" />
                <label class="form-check-label" asp-for="Page.IsHomePage">Set as Home Page</label>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow'
        });

        // Initialize with existing content
        quill.root.innerHTML = document.getElementById('pageBody').value;

        quill.on('text-change', function() {
            document.getElementById('pageBody').value = quill.root.innerHTML;
        });
    </script>
}
