@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Pages.DeleteModel
@{
    ViewData["Title"] = "Delete Page";
    Layout = "_AdminLayout";
}

<h1>Delete Page</h1>

<h3>Are you sure you want to delete this page?</h3>

<div>
    <h4>Page</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Page Title</dt>
        <dd class="col-sm-10">@Model.Page?.PageTitle</dd>

        <dt class="col-sm-2">Page URL</dt>
        <dd class="col-sm-10">@Model.Page?.PageURL</dd>

        <dt class="col-sm-2">Is Home Page</dt>
        <dd class="col-sm-10">@(Model.Page?.IsHomePage == true ? "Yes" : "No")</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Page.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
