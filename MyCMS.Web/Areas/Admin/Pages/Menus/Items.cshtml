@page "{menuId}"
@model MyCMS.Web.Areas.Admin.Pages.Menus.ItemsModel
@{
    ViewData["Title"] = "Menu Items";
    Layout = "_AdminLayout";
}

<h1>Menu Items</h1>

<p>
    <a asp-page="./CreateItem" asp-route-menuId="@Model.MenuId" class="btn btn-primary">Create New Item</a>
    <a asp-page="./Index" class="btn btn-secondary">Back to Menus</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Item Name</th>
            <th>Menu URL</th>
            <th>Parent</th>
            <th>Position</th>
            <th>Visibility</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.MenuItems != null)
        {
            @foreach (var item in Model.MenuItems)
            {
                <tr>
                    <td>@item.ItemName</td>
                    <td>@item.MenuURL</td>
                    <td>@item.ParentMenuItem</td>
                    <td>@item.ItemPosition</td>
                    <td>
                        @if (item.Visibility)
                        {
                            <span class="badge bg-success">Visible</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Hidden</span>
                        }
                    </td>
                    <td>
                        <a asp-page="./EditItem" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-page="./DeleteItem" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
