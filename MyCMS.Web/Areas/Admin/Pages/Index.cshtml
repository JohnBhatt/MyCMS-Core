@page
@model MyCMS.Web.Areas.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<h1>Dashboard</h1>

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Pages</h5>
                <p class="card-text display-4" id="totalPages">-</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Articles</h5>
                <p class="card-text display-4" id="totalArticles">-</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Users</h5>
                <p class="card-text display-4" id="totalUsers">-</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Quizzes</h5>
                <p class="card-text display-4" id="totalQuizzes">-</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5>Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-flex gap-2">
                    <a asp-page="/Pages/Create" class="btn btn-primary">Create Page</a>
                    <a asp-page="/Articles/Create" class="btn btn-success">Create Article</a>
                    <a asp-page="/Menus/Create" class="btn btn-info">Create Menu</a>
                    <a asp-page="/Quizzes/Create" class="btn btn-warning">Create Quiz</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Load statistics (placeholder - will be implemented with API calls)
        document.getElementById('totalPages').textContent = '0';
        document.getElementById('totalArticles').textContent = '0';
        document.getElementById('totalUsers').textContent = '0';
        document.getElementById('totalQuizzes').textContent = '0';
    </script>
}
