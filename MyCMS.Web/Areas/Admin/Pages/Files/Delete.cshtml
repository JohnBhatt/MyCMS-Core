@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Files.DeleteModel
@{
    ViewData["Title"] = "Delete File";
    Layout = "_AdminLayout";
}

<h1>Delete File</h1>

<h3>Are you sure you want to delete this file?</h3>

<div>
    <h4>Upload</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Document Name</dt>
        <dd class="col-sm-10">@Model.Upload?.DocumentName</dd>

        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.Upload?.DocumentType</dd>

        <dt class="col-sm-2">File Path</dt>
        <dd class="col-sm-10">@Model.Upload?.FilePath</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Upload.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
