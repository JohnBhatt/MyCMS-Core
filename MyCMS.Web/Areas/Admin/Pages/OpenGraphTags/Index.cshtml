@page
@model MyCMS.Web.Areas.Admin.Pages.OpenGraphTags.IndexModel
@{
    ViewData["Title"] = "OpenGraph Tags";
    Layout = "_AdminLayout";
}

<h1>OpenGraph Tags</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Tag</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Tag Name</th>
            <th>Property</th>
            <th>Content</th>
            <th>Visibility</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Tags != null)
        {
            @foreach (var tag in Model.Tags)
            {
                <tr>
                    <td>@tag.TagName</td>
                    <td>@tag.TagProperty</td>
                    <td>@tag.TagContent</td>
                    <td>
                        @if (tag.Visibility)
                        {
                            <span class="badge bg-success">Visible</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Hidden</span>
                        }
                    </td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@tag.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-page="./Delete" asp-route-id="@tag.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
