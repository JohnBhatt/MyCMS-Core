@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Articles.DeleteModel
@{
    ViewData["Title"] = "Delete Article";
    Layout = "_AdminLayout";
}

<h1>Delete Article</h1>

<h3>Are you sure you want to delete this article?</h3>

<div>
    <h4>Article</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Article?.Title</dd>

        <dt class="col-sm-2">Slug</dt>
        <dd class="col-sm-10">@Model.Article?.Slug</dd>

        <dt class="col-sm-2">Is Published</dt>
        <dd class="col-sm-10">@(Model.Article?.IsPublished == true ? "Yes" : "No")</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Article.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
