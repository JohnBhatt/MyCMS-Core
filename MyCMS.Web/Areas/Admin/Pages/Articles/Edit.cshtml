@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Articles.EditModel
@{
    ViewData["Title"] = "Edit Article";
    Layout = "_AdminLayout";
}

<h1>Edit Article</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Article.Id" />

            <div class="form-group mb-3">
                <label asp-for="Article.Title" class="control-label"></label>
                <input asp-for="Article.Title" class="form-control" required />
                <span asp-validation-for="Article.Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.Slug" class="control-label"></label>
                <input asp-for="Article.Slug" class="form-control" required />
                <span asp-validation-for="Article.Slug" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.CategoryId" class="control-label">Category</label>
                <select asp-for="Article.CategoryId" class="form-control" asp-items="Model.Categories" required>
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="Article.CategoryId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.MetaDescription" class="control-label">Meta Description</label>
                <textarea asp-for="Article.MetaDescription" class="form-control" rows="2"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.MetaKeywords" class="control-label">Meta Keywords</label>
                <input asp-for="Article.MetaKeywords" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.Content" class="control-label">Content</label>
                <div id="editor-container" style="height: 400px;"></div>
                <input type="hidden" asp-for="Article.Content" id="articleContent" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.Tags" class="control-label">Tags</label>
                <input asp-for="Article.Tags" class="form-control" placeholder="Comma separated tags" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Featured Image</label>
                <input type="file" name="FeaturedImageFile" class="form-control" />
                @if (!string.IsNullOrEmpty(Model.Article.FeaturedImage))
                {
                    <div class="mt-2">
                        <img src="@Model.Article.FeaturedImage" alt="Featured" style="max-width: 200px;" />
                    </div>
                }
            </div>

            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Article.IsPublished" />
                <label class="form-check-label" asp-for="Article.IsPublished">Published</label>
            </div>

            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Article.IsFeatured" />
                <label class="form-check-label" asp-for="Article.IsFeatured">Featured Article</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.FeaturedFrom" class="control-label">Featured From</label>
                <input asp-for="Article.FeaturedFrom" type="date" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Article.FeaturedUpto" class="control-label">Featured Until</label>
                <input asp-for="Article.FeaturedUpto" type="date" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow'
        });

        quill.root.innerHTML = document.getElementById('articleContent').value;

        quill.on('text-change', function() {
            document.getElementById('articleContent').value = quill.root.innerHTML;
        });
    </script>
}
