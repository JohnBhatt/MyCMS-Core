@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
    Layout = "_AdminLayout";
}

<h1>Delete User</h1>

<h3>Are you sure you want to delete this user?</h3>

<div>
    <h4>User</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@Model.User?.UserName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.User?.Email</dd>

        <dt class="col-sm-2">First Name</dt>
        <dd class="col-sm-10">@Model.User?.FirstName</dd>

        <dt class="col-sm-2">Last Name</dt>
        <dd class="col-sm-10">@Model.User?.LastName</dd>

        <dt class="col-sm-2">Role</dt>
        <dd class="col-sm-10">@Model.User?.UserRole</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="User.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
