@page "{id}"
@model MyCMS.Web.Areas.Admin.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit User";
    Layout = "_AdminLayout";
}

<h1>Edit User</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="User.Id" />

            <div class="form-group mb-3">
                <label asp-for="User.Email" class="control-label"></label>
                <input asp-for="User.Email" class="form-control" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="User.FirstName" class="control-label"></label>
                <input asp-for="User.FirstName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="User.LastName" class="control-label"></label>
                <input asp-for="User.LastName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="User.UserRole" class="control-label">Role</label>
                <select asp-for="User.UserRole" class="form-control">
                    <option value="">-- Select Role --</option>
                    <option value="Admin">Admin</option>
                    <option value="Editor">Editor</option>
                    <option value="User">User</option>
                </select>
            </div>

            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="User.IsAuthorized" />
                <label class="form-check-label" asp-for="User.IsAuthorized">Authorized</label>
            </div>

            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="User.IsSuspended" />
                <label class="form-check-label" asp-for="User.IsSuspended">Suspended</label>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
