@model List<MyCMS.Core.Entities.Quiz>
@{
    ViewData["Title"] = "Quizzes";
    Layout = "_AdminLayout";
}

<h1>Quizzes</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Quiz</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Time Limit (minutes)</th>
            <th>Passing Score (%)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            @foreach (var quiz in Model)
            {
                <tr>
                    <td>@quiz.Title</td>
                    <td>@quiz.Description</td>
                    <td>@quiz.StartTime?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@quiz.EndTime?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@quiz.TimeLimitMinutes</td>
                    <td>@quiz.PassingScore</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@quiz.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@quiz.Id" class="btn btn-sm btn-danger">Delete</a>
                        <a asp-action="Questions" asp-route-quizId="@quiz.Id" class="btn btn-sm btn-info">Questions</a>
                        <a asp-action="Results" asp-route-id="@quiz.Id" class="btn btn-sm btn-secondary">Results</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
