@model string
@{
    var inputId = ViewData["InputId"] as string ?? "filePickerInput";
    var previewId = ViewData["PreviewId"] as string ?? "filePickerPreview";
    var label = ViewData["Label"] as string ?? "Select File";
    var accept = ViewData["Accept"] as string ?? "*";
}

<div class="form-group mb-3">
    <label class="control-label">@label</label>
    <div class="input-group">
        <input type="text" class="form-control" id="@inputId" placeholder="Select or upload a file" readonly value="@Model" />
        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#mediaLibraryModal" onclick="initMediaLibrary('@inputId', '@previewId')">
            <i class="bi bi-images"></i> Media Library
        </button>
    </div>
    <div class="mt-2" id="@previewId" style="display: none;">
        <img src="@Model" alt="Preview" style="max-width: 200px; max-height: 200px;" class="img-thumbnail" />
    </div>
    @if (!string.IsNullOrEmpty(Model))
    {
        <script>
            document.getElementById('@previewId').style.display = 'block';
        </script>
    }
</div>
