<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - MyCMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <nav class="bg-dark text-white" style="width: 250px; min-height: 100vh;">
            <div class="p-3">
                <h5><i class="bi bi-speedometer2 me-2"></i>MyCMS Admin</h5>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link text-white active" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-house-door me-2"></i>Dashboard
                    </a>
                </li>
                
                <li class="nav-item mt-3 mb-1">
                    <small class="text-white-50 px-3 text-uppercase fw-bold">Content Management</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Articles" asp-action="Index">
                        <i class="bi bi-file-text me-2"></i>Articles
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-tags me-2"></i>Categories
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Pages" asp-action="Index">
                        <i class="bi bi-file-earmark me-2"></i>Pages
                    </a>
                </li>
                
                <li class="nav-item mt-3 mb-1">
                    <small class="text-white-50 px-3 text-uppercase fw-bold">Media</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Files" asp-action="Index">
                        <i class="bi bi-images me-2"></i>Files
                    </a>
                </li>
                
                <li class="nav-item mt-3 mb-1">
                    <small class="text-white-50 px-3 text-uppercase fw-bold">Site Structure</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Menus" asp-action="Index">
                        <i class="bi bi-list me-2"></i>Menus
                    </a>
                </li>
                
                <li class="nav-item mt-3 mb-1">
                    <small class="text-white-50 px-3 text-uppercase fw-bold">Interactive</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Quizzes" asp-action="Index">
                        <i class="bi bi-question-circle me-2"></i>Quizzes
                    </a>
                </li>
                
                <li class="nav-item mt-3 mb-1">
                    <small class="text-white-50 px-3 text-uppercase fw-bold">System</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Users
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Configuration" asp-action="Index">
                        <i class="bi bi-gear me-2"></i>Configuration
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                        <i class="bi bi-sliders me-2"></i>Settings
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Themes" asp-action="Index">
                        <i class="bi bi-palette me-2"></i>Themes
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="OpenGraphTags" asp-action="Index">
                        <i class="bi bi-share me-2"></i>OpenGraph Tags
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="AuditLog" asp-action="Index">
                        <i class="bi bi-clock-history me-2"></i>Audit Log
                    </a>
                </li>
                
                <li class="nav-item mt-4">
                    <hr class="border-secondary">
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index" target="_blank">
                        <i class="bi bi-box-arrow-up-right me-2"></i>Back to Site
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Main Content -->
        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
