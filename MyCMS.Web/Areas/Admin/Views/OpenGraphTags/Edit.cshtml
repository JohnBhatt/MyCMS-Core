@model MyCMS.Core.Entities.OpenGraphTag
@{
    ViewData["Title"] = "Edit OpenGraph Tag";
    Layout = "_AdminLayout";
}

<h1>Edit OpenGraph Tag</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="TagName" class="control-label"></label>
                <input asp-for="TagName" class="form-control" required />
                <span asp-validation-for="TagName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TagProperty" class="control-label">Property</label>
                <input asp-for="TagProperty" class="form-control" placeholder="e.g., og:title, og:description" />
                <span asp-validation-for="TagProperty" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TagContent" class="control-label">Content</label>
                <textarea asp-for="TagContent" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="Visibility" />
                <label class="form-check-label" asp-for="Visibility">Visible</label>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
