@model MyCMS.Core.Entities.OpenGraphTag
@{
    ViewData["Title"] = "Delete OpenGraph Tag";
    Layout = "_AdminLayout";
}

<h1>Delete OpenGraph Tag</h1>

<h3>Are you sure you want to delete this tag?</h3>

<div>
    <h4>OpenGraph Tag</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Tag Name</dt>
        <dd class="col-sm-10">@Model?.TagName</dd>

        <dt class="col-sm-2">Property</dt>
        <dd class="col-sm-10">@Model?.TagProperty</dd>

        <dt class="col-sm-2">Content</dt>
        <dd class="col-sm-10">@Model?.TagContent</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
