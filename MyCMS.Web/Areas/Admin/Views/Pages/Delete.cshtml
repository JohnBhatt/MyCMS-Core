@model MyCMS.Core.Entities.Page
@{
    ViewData["Title"] = "Delete Page";
    Layout = "_AdminLayout";
}

<h1>Delete Page</h1>

<h3>Are you sure you want to delete this page?</h3>

<div>
    <h4>Page</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Page Title</dt>
        <dd class="col-sm-10">@Model?.PageTitle</dd>

        <dt class="col-sm-2">Page URL</dt>
        <dd class="col-sm-10">@Model?.PageURL</dd>

        <dt class="col-sm-2">Is Home Page</dt>
        <dd class="col-sm-10">@(Model?.IsHomePage == true ? "Yes" : "No")</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
