@model MyCMS.Core.Entities.Configuration
@{
    ViewData["Title"] = "Configuration";
    Layout = "_AdminLayout";
}

<h1>Site Configuration</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <h4>General Settings</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="SiteName" class="control-label"></label>
                <input asp-for="SiteName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Slogan" class="control-label"></label>
                <input asp-for="Slogan" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="BaseURL" class="control-label">Base URL</label>
                <input asp-for="BaseURL" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="FooterText" class="control-label">Footer Text</label>
                <textarea asp-for="FooterText" class="form-control" rows="2"></textarea>
            </div>

            <h4>Theme</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="ThemeName" class="control-label">Default Theme</label>
                <select asp-for="ThemeName" class="form-control">
                    <option value="">-- Select Theme --</option>
                    @if (ViewBag.Themes != null)
                    {
                        @foreach (var theme in ViewBag.Themes)
                        {
                            <option value="@theme.Name" selected="@((Model.ThemeName == theme.Name) ? "selected" : null)">@theme.DisplayName</option>
                        }
                    }
                </select>
                <small class="form-text text-muted">Select the default theme for your site. This will be applied on first install and can be changed later.</small>
            </div>

            <h4>Social Media</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="FacebookLink" class="control-label">Facebook</label>
                <input asp-for="FacebookLink" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="LinkedInLink" class="control-label">LinkedIn</label>
                <input asp-for="LinkedInLink" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="TwitterLink" class="control-label">Twitter</label>
                <input asp-for="TwitterLink" class="form-control" />
            </div>

            <h4>SEO</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="Keywords" class="control-label">Meta Keywords</label>
                <input asp-for="Keywords" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="MetaDesc" class="control-label">Meta Description</label>
                <textarea asp-for="MetaDesc" class="form-control" rows="2"></textarea>
            </div>

            <h4>Sitemap</h4>
            <hr />
            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="SitemapEnabled" />
                <label class="form-check-label" asp-for="SitemapEnabled">Enable Sitemap</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SitemapPriority" class="control-label">Default Priority</label>
                <input asp-for="SitemapPriority" type="number" step="0.1" min="0" max="1" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="SitemapChangeFrequency" class="control-label">Change Frequency</label>
                <select asp-for="SitemapChangeFrequency" class="form-control">
                    <option value="always">Always</option>
                    <option value="hourly">Hourly</option>
                    <option value="daily">Daily</option>
                    <option value="weekly">Weekly</option>
                    <option value="monthly">Monthly</option>
                    <option value="yearly">Yearly</option>
                    <option value="never">Never</option>
                </select>
            </div>

            <h4>RSS Feed</h4>
            <hr />
            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="RSSFeedEnabled" />
                <label class="form-check-label" asp-for="RSSFeedEnabled">Enable RSS Feed</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RSSFeedTitle" class="control-label">Feed Title</label>
                <input asp-for="RSSFeedTitle" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="RSSFeedItemCount" class="control-label">Item Count</label>
                <input asp-for="RSSFeedItemCount" type="number" class="form-control" />
            </div>

            <h4>Custom Scripts</h4>
            <hr />
            <div class="form-group mb-3">
                <label asp-for="HeadScript" class="control-label">Head Script (Google Analytics, Adsense, etc.)</label>
                <textarea asp-for="HeadScript" class="form-control" rows="5"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BodyScript" class="control-label">Body Script</label>
                <textarea asp-for="BodyScript" class="form-control" rows="5"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="GoogleAnalyticsId" class="control-label">Google Analytics ID</label>
                <input asp-for="GoogleAnalyticsId" class="form-control" placeholder="UA-XXXXX-X" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="GoogleAdsenseId" class="control-label">Google Adsense ID</label>
                <input asp-for="GoogleAdsenseId" class="form-control" placeholder="ca-pub-XXXXXXXXXXXXXXXX" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="FacebookPixelId" class="control-label">Facebook Pixel ID</label>
                <input asp-for="FacebookPixelId" class="form-control" placeholder="XXXXXXXXXXXXXXXX" />
            </div>

            <h4>AMP</h4>
            <hr />
            <div class="form-group mb-3 form-check">
                <input class="form-check-input" asp-for="AMPEnabled" />
                <label class="form-check-label" asp-for="AMPEnabled">Enable AMP</label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AMPAnalyticsId" class="control-label">AMP Analytics ID</label>
                <input asp-for="AMPAnalyticsId" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="AMPLogoUrl" class="control-label">AMP Logo URL</label>
                <input asp-for="AMPLogoUrl" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="AMPublisherName" class="control-label">Publisher Name</label>
                <input asp-for="AMPublisherName" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Save Configuration" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
