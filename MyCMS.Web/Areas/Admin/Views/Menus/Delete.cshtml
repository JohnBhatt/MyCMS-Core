@model MyCMS.Core.Entities.Menu
@{
    ViewData["Title"] = "Delete Menu";
    Layout = "_AdminLayout";
}

<h1>Delete Menu</h1>

<h3>Are you sure you want to delete this menu?</h3>

<div>
    <h4>Menu</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Menu Name</dt>
        <dd class="col-sm-10">@Model?.MenuName</dd>

        <dt class="col-sm-2">Position</dt>
        <dd class="col-sm-10">@Model?.Position</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model?.MenuDesc</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
