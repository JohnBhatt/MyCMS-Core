@model List<MyCMS.Core.Entities.Menu>
@{
    ViewData["Title"] = "Menus";
    Layout = "_AdminLayout";
}

<h1>Menus</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Menu</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Menu Name</th>
            <th>Position</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            @foreach (var menu in Model)
            {
                <tr>
                    <td>@menu.MenuName</td>
                    <td>@menu.Position</td>
                    <td>@menu.MenuDesc</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@menu.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@menu.Id" class="btn btn-sm btn-danger">Delete</a>
                        <a asp-action="Items" asp-route-menuId="@menu.Id" class="btn btn-sm btn-info">Manage Items</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
