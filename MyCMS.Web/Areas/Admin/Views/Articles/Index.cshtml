@model List<MyCMS.Core.Entities.Article>
@{
    ViewData["Title"] = "Articles";
    Layout = "_AdminLayout";
}

<h1>Articles</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Article</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Slug</th>
            <th>Category</th>
            <th>Is Published</th>
            <th>Is Featured</th>
            <th>View Count</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            @foreach (var article in Model)
            {
                <tr>
                    <td>@article.Title</td>
                    <td>@article.Slug</td>
                    <td>@article.CategoryId</td>
                    <td>
                        @if (article.IsPublished)
                        {
                            <span class="badge bg-success">Published</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                    </td>
                    <td>
                        @if (article.IsFeatured)
                        {
                            <span class="badge bg-primary">Featured</span>
                        }
                    </td>
                    <td>@article.ViewCount</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@article.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@article.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
