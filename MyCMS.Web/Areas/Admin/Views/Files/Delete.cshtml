@model MyCMS.Core.Entities.Upload
@{
    ViewData["Title"] = "Delete File";
    Layout = "_AdminLayout";
}

<h1>Delete File</h1>

<h3>Are you sure you want to delete this file?</h3>

<div>
    <h4>Upload</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Document Name</dt>
        <dd class="col-sm-10">@Model?.DocumentName</dd>

        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model?.DocumentType</dd>

        <dt class="col-sm-2">File Path</dt>
        <dd class="col-sm-10">@Model?.FilePath</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
