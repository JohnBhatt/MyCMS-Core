@model MyCMS.Core.Entities.Upload
@{
    ViewData["Title"] = "Upload File";
    Layout = "_AdminLayout";
}

<h1>Upload File</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post" enctype="multipart/form-data" asp-action="Upload">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label class="control-label">File</label>
                <input type="file" name="file" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Folder</label>
                <select name="folder" class="form-control">
                    <option value="images">Images</option>
                    <option value="documents">Documents</option>
                    <option value="videos">Videos</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DocumentName" class="control-label">Document Name</label>
                <input asp-for="DocumentName" class="form-control" required />
                <span asp-validation-for="DocumentName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DocumentType" class="control-label">Document Type</label>
                <input asp-for="DocumentType" class="form-control" required />
                <span asp-validation-for="DocumentType" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FileDesc" class="control-label">Description</label>
                <textarea asp-for="FileDesc" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mb-3">
                <input type="submit" value="Upload" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>
