@model MyCMS.Core.Entities.Setting
@{
    ViewData["Title"] = "Create Setting";
    Layout = "_AdminLayout";
}

<h1>Create New Setting</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">Setting Key</label>
                        <input asp-for="Key" class="form-control" placeholder="e.g., Social.Twitter" required />
                        <small class="form-text text-muted">Use dots for organization: Category.SettingName</small>
                        <span asp-validation-for="Key" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label">Category</label>
                        <select asp-for="Category" class="form-select">
                            <option value="General">General</option>
                            <option value="Social">Social Media</option>
                            <option value="SEO">SEO</option>
                            <option value="Analytics">Analytics</option>
                            <option value="Theme">Theme</option>
                            <option value="Email">Email</option>
                            <option value="Security">Security</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Value" class="form-label">Value</label>
                        <textarea asp-for="Value" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Value" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="What is this setting used for?"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsEditable" type="checkbox" class="form-check-input" checked />
                        <label asp-for="IsEditable" class="form-check-label">Allow editing</label>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsEncrypted" type="checkbox" class="form-check-input" />
                        <label asp-for="IsEncrypted" class="form-check-label">Encrypt this value</label>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Reason (for audit log)</label>
                        <input type="text" name="changeReason" class="form-control" placeholder="e.g., Adding new social media link" required />
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">Create Setting</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
