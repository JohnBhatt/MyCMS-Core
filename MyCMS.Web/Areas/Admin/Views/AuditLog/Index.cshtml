@model IEnumerable<MyCMS.Core.Entities.AuditLog>
@{
    ViewData["Title"] = "Audit Log";
    Layout = "_AdminLayout";
}

<h1>Audit Log</h1>
<p class="text-muted">Track all changes across the system</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<!-- Filters -->
<div class="card mb-3">
    <div class="card-header">
        <i class="bi bi-funnel"></i> Filters
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Table</label>
                <select name="tableName" class="form-select" asp-items="ViewBag.TableNames">
                    <option value="">All Tables</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Action</label>
                <select name="action" class="form-select" asp-items="ViewBag.Actions">
                    <option value="">All Actions</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">User</label>
                <select name="userId" class="form-select" asp-items="ViewBag.Users">
                    <option value="">All Users</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">From Date</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.CurrentFromDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">To Date</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.CurrentToDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control" placeholder="Search..." value="@ViewBag.CurrentSearch" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Apply Filters</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Clear</a>
                
                <!-- Export button (placeholder) -->
                <button type="button" class="btn btn-outline-success float-end" disabled title="Coming soon">
                    <i class="bi bi-download"></i> Export CSV
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Active Filters Display -->
@if (!string.IsNullOrEmpty(ViewBag.CurrentTableName) || 
    !string.IsNullOrEmpty(ViewBag.CurrentAction) ||
    ViewBag.CurrentUserId != null ||
    !string.IsNullOrEmpty(ViewBag.CurrentFromDate) ||
    !string.IsNullOrEmpty(ViewBag.CurrentToDate) ||
    !string.IsNullOrEmpty(ViewBag.CurrentSearch))
{
    <div class="mb-3">
        <span class="fw-bold">Active Filters:</span>
        @if (!string.IsNullOrEmpty(ViewBag.CurrentTableName))
        {
            <span class="badge bg-primary me-1">Table: @ViewBag.CurrentTableName</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.CurrentAction))
        {
            <span class="badge bg-info me-1">Action: @ViewBag.CurrentAction</span>
        }
        @if (ViewBag.CurrentUserId != null)
        {
            <span class="badge bg-secondary me-1">User: @ViewBag.CurrentUserId</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.CurrentFromDate))
        {
            <span class="badge bg-warning me-1">From: @ViewBag.CurrentFromDate</span>
        }
        @if (!string.IsNullOrEmpty(ViewBag.CurrentToDate))
        {
            <span class="badge bg-warning me-1">To: @ViewBag.CurrentToDate</span>
        }
    </div>
}

<!-- Results Count -->
<div class="mb-2">
    <span class="text-muted">Showing @Model.Count() of @ViewBag.TotalCount records</span>
</div>

<!-- Audit Log Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Date/Time</th>
                        <th>Table</th>
                        <th>Action</th>
                        <th>Record ID</th>
                        <th>User</th>
                        <th>Reason</th>
                        <th>IP Address</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.CreatedOn.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>
                                <span class="badge bg-secondary">@log.TableName</span>
                            </td>
                            <td>
                                <span class="badge @(log.Action switch {
                                    "Created" => "bg-success",
                                    "Updated" => "bg-warning text-dark",
                                    "Deleted" => "bg-danger",
                                    _ => "bg-secondary"
                                })">@log.Action</span>
                            </td>
                            <td>
                                <code class="small">@(log.RecordId.Length > 15 ? log.RecordId.Substring(0, 15) + "..." : log.RecordId)</code>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(log.ModifiedByUserName))
                                {
                                    <a asp-action="ByUser" asp-route-userId="@log.ModifiedBy">
                                        @log.ModifiedByUserName
                                    </a>
                                }
                                else if (log.ModifiedBy.HasValue)
                                {
                                    <span class="text-muted">@log.ModifiedBy.Value.ToString().Substring(0, 8)...</span>
                                }
                                else
                                {
                                    <span class="text-muted">System</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(log.ChangeReason))
                                {
                                    <span title="@log.ChangeReason">
                                        @(log.ChangeReason.Length > 30 ? log.ChangeReason.Substring(0, 30) + "..." : log.ChangeReason)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td><code class="small">@log.IpAddress</code></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                <a asp-action="ByRecord" asp-route-tableName="@log.TableName" asp-route-recordId="@log.RecordId" class="btn btn-sm btn-info">
                                    <i class="bi bi-list"></i> History
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Audit log pagination" class="mt-3">
        <ul class="pagination justify-content-center">
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" 
                       asp-route-tableName="@ViewBag.CurrentTableName"
                       asp-route-action="@ViewBag.CurrentAction"
                       asp-route-userId="@ViewBag.CurrentUserId"
                       asp-route-fromDate="@ViewBag.CurrentFromDate"
                       asp-route-toDate="@ViewBag.CurrentToDate"
                       asp-route-search="@ViewBag.CurrentSearch"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                        Previous
                    </a>
                </li>
            }
            
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-tableName="@ViewBag.CurrentTableName"
                       asp-route-action="@ViewBag.CurrentAction"
                       asp-route-userId="@ViewBag.CurrentUserId"
                       asp-route-fromDate="@ViewBag.CurrentFromDate"
                       asp-route-toDate="@ViewBag.CurrentToDate"
                       asp-route-search="@ViewBag.CurrentSearch"
                       asp-route-page="@i">@i</a>
                </li>
            }
            
            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-tableName="@ViewBag.CurrentTableName"
                       asp-route-action="@ViewBag.CurrentAction"
                       asp-route-userId="@ViewBag.CurrentUserId"
                       asp-route-fromDate="@ViewBag.CurrentFromDate"
                       asp-route-toDate="@ViewBag.CurrentToDate"
                       asp-route-search="@ViewBag.CurrentSearch"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Management Actions -->
<div class="card mt-3">
    <div class="card-header">
        <i class="bi bi-gear"></i> Log Management
    </div>
    <div class="card-body">
        <form asp-action="ClearOldLogs" method="post" onsubmit="return confirm('Are you sure you want to delete old audit logs? This action cannot be undone.');">
            <div class="row align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Clear logs older than (days)</label>
                    <input type="number" name="daysToKeep" class="form-control" value="90" min="1" max="365" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Clear Old Logs
                    </button>
                </div>
                <div class="col-md-4 text-end">
                    <span class="text-muted">Total logs in database: <strong>@ViewBag.TotalCount</strong></span>
                </div>
            </div>
        </form>
    </div>
</div>
