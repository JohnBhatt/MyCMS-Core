@page
@model MyCMS.Web.Pages.Articles.IndexModel
@{
    ViewData["Title"] = "Articles";
    Layout = "_Layout";
}

<h1>Articles</h1>

<div class="container mt-4">
    <div class="row">
        @if (Model.Articles != null && Model.Articles.Any())
        {
            @foreach (var article in Model.Articles)
            {
                <div class="col-md-12 mb-4">
                    <div class="card">
                        @if (!string.IsNullOrEmpty(article.FeaturedImage))
                        {
                            <img src="@article.FeaturedImage" class="card-img-top" alt="@article.Title">
                        }
                        <div class="card-body">
                            <h2 class="card-title">
                                <a asp-page="./Details" asp-route-slug="@article.Slug">@article.Title</a>
                            </h2>
                            <p class="card-text text-muted">
                                Published: @article.PublishedDate?.ToString("MMMM dd, yyyy") | Views: @article.ViewCount
                            </p>
                            <p class="card-text">@article.MetaDescription</p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-md-12">
                <p>No articles found.</p>
            </div>
        }
    </div>
</div>
