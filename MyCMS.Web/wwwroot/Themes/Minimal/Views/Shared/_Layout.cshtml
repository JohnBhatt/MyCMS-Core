<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyCMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Themes/Minimal/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MyCMS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Article" asp-action="Index">Articles</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Page" asp-action="Index">About</a></li>
                </ul>
                <form class="search-form d-flex" asp-controller="Search" asp-action="Index" method="get">
                    <input type="search" name="q" placeholder="Search..." class="w-100">
                </form>
                @await Component.InvokeAsync("LoginPartial")
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer>
        <div class="container text-center">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="footer-link">Home</a>
            <a asp-area="" asp-controller="Article" asp-action="Index" class="footer-link">Articles</a>
            <a asp-area="" asp-controller="Page" asp-action="Index" class="footer-link">About</a>
            <div class="social-links mt-4 mb-4">
                <a href="#" class="social-link">𝕏</a>
                <a href="#" class="social-link">in</a>
                <a href="#" class="social-link">📷</a>
            </div>
            <p class="text-muted small">&copy; 2026 MyCMS. All rights reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
