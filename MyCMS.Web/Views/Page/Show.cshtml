@model MyCMS.Core.Entities.Page
@{
    ViewData["Title"] = Model?.PageTitle ?? "Page";
    Layout = "_Layout";
}

@if (Model != null)
{
    <div class="container mt-4">
        <h1>@Model.PageTitle</h1>
        <div class="content">
            @Html.Raw(Model.PageBody)
        </div>
    </div>
}
else
{
    <div class="container mt-4">
        <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or has been deleted.</p>
    <a asp-action="Index" asp-controller="Home" class="btn btn-primary">Back to Home</a>
    </div>
}
