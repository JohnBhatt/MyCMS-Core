@{
    ViewData["Title"] = "Error";
}

<div class="hero-section">
    <div class="container text-center">
        <h1 style="font-size: 5rem; font-weight: 700;">404</h1>
        <p style="font-size: 1.5rem; color: var(--secondary-color);">Page not found</p>
