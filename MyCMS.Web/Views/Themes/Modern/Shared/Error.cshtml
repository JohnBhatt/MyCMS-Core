@{
    ViewData["Title"] = "Error";
}

<div class="hero-section text-center">
    <div class="container">
        <div style="font-size: 8rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 1rem;">404</div>
        <h2 style="font-weight: 700; margin-bottom: 1rem;">Page Not Found</h2>
        <p style="color: rgba(255,255,255,0.8); margin-bottom: 2rem;">The page you're looking for doesn't exist or has been moved.</p>
        <a href="@Url.Action("Index", "Home")" class="btn btn-gradient btn-lg">Return to Home</a>
    </div>
</div>
