@{
    ViewData["Title"] = "Home";
    Layout = ViewBag.ThemeLayout ?? "/Views/Themes/Minimal/Shared/_Layout.cshtml";
}

@if (ViewBag.HomePage != null)
{
    <div class="hero-section">
        <div class="container">
            <h1>@ViewBag.HomePage.PageTitle</h1>
            <p>@ViewBag.HomePage.MetaDescription</p>
        </div>
    </div>
    <div class="container">
        <div class="content">
            @Html.Raw(ViewBag.HomePage.PageBody)
        </div>
    </div>
}
else
{
    <div class="hero-section">
        <div class="container">
            <h1>Welcome to MyCMS</h1>
            <p>Your content management system is ready. Start creating amazing content.</p>
            <a href="@Url.Action("Index", "Article")" class="btn btn-gradient">Browse Articles</a>
        </div>
    </div>
}

@if (ViewBag.FeaturedArticles is List<Article> featuredArticles && featuredArticles.Any())
{
    <div class="container my-5">
        <h3 class="section-title">Latest Articles</h3>
        <div class="article-list">
            @foreach (var article in featuredArticles)
            {
                <div class="article-item">
                    <div class="article-meta">
                        <span>@article.Category?.CategoryName</span> • <span>@article.PublishedDate?.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <h2>
                        <a asp-action="Details" asp-controller="Article" asp-route-slug="@article.Slug">@article.Title</a>
                    </h2>
                    <p class="article-excerpt">@article.MetaDescription</p>
                    <a asp-action="Details" asp-controller="Article" asp-route-slug="@article.Slug" class="read-more">Read article →</a>
                </div>
            }
        </div>
    </div>
}
