@model Article
@{
    ViewData["Title"] = Model?.Title ?? "Article";
    Layout = ViewBag.ThemeLayout ?? "/Views/Themes/Minimal/Shared/_Layout.cshtml";
}

@if (Model != null)
{
    <div class="hero-section">
        <div class="container">
            <h1>@Model.Title</h1>
            <p class="article-meta">
                <span>@Model.Category?.CategoryName</span> • <span>@(Model.PublishedDate?.ToString("MMMM dd, yyyy"))</span> • <span>@Model.ViewCount views</span>
            </p>
        </div>
    </div>

    <div class="container my-5">
        <article class="article-content">
            @if (!string.IsNullOrEmpty(Model.FeaturedImage))
            {
                <img src="@Model.FeaturedImage" class="featured-image mb-4" alt="@Model.Title">
            }
            <div class="content">
                @Html.Raw(Model.Content)
            </div>
        </article>
    </div>

    @if (ViewBag.AmpHtml != null)
    {
        <link rel="amphtml" href="@Model.Slug/amp" />
    }
}
else
{
    <div class="hero-section">
        <div class="container">
            <h1>Article Not Found</h1>
            <p>The article you're looking for doesn't exist or has been deleted.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-gradient">Back to Home</a>
        </div>
    </div>
}
